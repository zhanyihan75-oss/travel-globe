.bg-gallery {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-tile {
  position: absolute;
  border-radius: 10px;
  overflow: hidden;
  will-change: transform, opacity;
  transition: filter 1s ease;
}

.bg-tile-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
  user-select: none;
  opacity: 1;
  transition: opacity 1s ease;
}

/* 穹顶遮罩：靠近地球暗，远离地球亮 — 大幅调亮 */
.bg-gallery-mask {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background: radial-gradient(
    ellipse 28% 42% at 50% 50%,
    rgba(5, 7, 17, 0.7) 0%,
    rgba(5, 7, 17, 0.5) 12%,
    rgba(5, 7, 17, 0.25) 25%,
    rgba(5, 7, 17, 0.08) 40%,
    transparent 60%
  );
}

/* 上下暗角 — 调浅 */
.bg-gallery-vignette {
  position: fixed;
  left: 0;
  right: 0;
  height: 100px;
  z-index: 2;
  pointer-events: none;
}

.bg-gallery-vignette--top {
  top: 0;
  background: linear-gradient(to bottom, rgba(5, 7, 17, 0.6), transparent);
}

.bg-gallery-vignette--bottom {
  bottom: 0;
  background: linear-gradient(to top, rgba(5, 7, 17, 0.6), transparent);
}

@media (max-width: 768px) {
  .bg-tile {
    border-radius: 6px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .bg-tile-img {
    transition: none !important;
  }
}